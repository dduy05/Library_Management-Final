# Cấu hình Môi trường Backend Server
PORT=3000

# ========================================================
# THÔNG TIN KẾT NỐI POSTGRESQL
# (Bạn cần điền chính xác thông tin đăng nhập của bạn vào đây)
# ========================================================

# Tên máy chủ PostgreSQL của bạn (Sử dụng 127.0.0.1 thay vì localhost để tránh lỗi phân giải IPv6 trên Windows)
DB_HOST=127.0.0.1

# Cổng mặc định của PostgreSQL
DB_PORT=5432

# Tài khoản PostgreSQL (Mặc định khi cài là postgres)
DB_USER=postgres

# MẬT KHẨU POSTGRESQL (Thay bằng mật khẩu bạn đã thiết lập)
DB_PASSWORD=root

# Tên Database
DB_NAME=LibraryDB

